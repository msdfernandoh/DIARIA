{
  "expo": {
    "name": "Diária da Cidade",
    "slug": "diaria-cidade",
    "scheme": "diariadacidade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diariacidade.app",
      "associatedDomains": ["applinks:diariadacidade.app.br"]
    },
    "android": {
      "package": "com.diariacidade.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "diariadacidade.app.br",
              "pathPrefix": "/"
            }
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1557FF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Usamos a câmera para ler QR Codes de resgate de brindes."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
